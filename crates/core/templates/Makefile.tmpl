STAPPLER_ROOT ?= {{STAPPLER_ROOT}}
LOCAL_MAKEFILE := $(abspath $(lastword $(MAKEFILE_LIST)))

LOCAL_EXECUTABLE := {{EXE}}

# Paths are RELATIVE to the engine root: the build prepends $(GLOBAL_ROOT)/ to
# every non-absolute entry. Do NOT use $(STAPPLER_ROOT)/… here — on Windows an
# absolute `C:/…` path fails the engine's Unix-only `$(filter /%,…)` abs-path
# test, gets treated as relative, double-prefixed, and the modules go unfound.
LOCAL_MODULES_PATHS = \
	stappler/stappler-modules.mk \
	xenolith/xenolith-modules.mk

LOCAL_MODULES := \
	runtime \
	xenolith_application \
	xenolith_renderer_simpleui \
	xenolith_backend_vk \
	xenolith_resources_assets

LOCAL_SRCS_DIRS := src
LOCAL_INCLUDES_OBJS := src

include $(STAPPLER_ROOT)/make/universal.mk

