{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Xenolith Installer",
  "version": "0.1.1",
  "identifier": "studio.xenolith.installer",
  "build": {
    "beforeDevCommand": { "script": "pnpm dev", "cwd": "../../ui" },
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": { "script": "pnpm build", "cwd": "../../ui" },
    "frontendDist": "../../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Xenolith Installer",
        "width": 1000,
        "height": 700,
        "minWidth": 720,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/XenolithEngine/xenolith-installer/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI0MEZEOTI2MTZBNDgzMzkKUldRNWc2UVdKdGtQdEw2bDBWWmREZm5LZnEzQjU1ZkVRS2dCWnAwdjc0emlXV1lmK3NXVUNzdTMK"
    }
  }
}
